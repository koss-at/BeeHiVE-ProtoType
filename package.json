{
  "name": "beehive-proto2",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev:renderer": "vite --config app/renderer/vite.config.ts",
    "dev:main": "node app/main/build-watch.js",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev": "concurrently -k -n RND,MAIN,ELEC -c cyan,magenta,yellow \"yarn dev:renderer\" \"node app/main/build-watch.js\" \"yarn dev:electron\"",
    "build:renderer": "vite build --config app/renderer/vite.config.ts",
    "build": "yarn build:renderer",
    "start": "electron .",
    "dist:mac": "yarn build:renderer && electron-builder --mac",
    "dist:win": "yarn build:renderer && electron-builder --win",
    "dist": "yarn build:renderer && electron-builder -mwl"
  },
  "build": {
    "appId": "com.artteknika.beehive",
    "productName": "BeeHiVE",
    "asar": true,
    "files": [
      "index.js",
      "app/**",
      "dist/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.23",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.5",
    "vite": "^5.4.8",
    "wait-on": "^7.2.0"
  }
}
